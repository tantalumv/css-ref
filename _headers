# Cache static assets for 1 year
/*
  Cache-Control: public, max-age=31536000, immutable

# Don't cache HTML
/*.html
  Cache-Control: no-cache

# Cache bundle files
/dist/bundle.js
  Cache-Control: public, max-age=31536000, immutable

/dist/bundle.css
  Cache-Control: public, max-age=31536000, immutable
